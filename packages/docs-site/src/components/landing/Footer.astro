---
const columns = [
  {
    title: 'Documentation',
    links: [
      { label: 'Introduction', href: '/getting-started/introduction/' },
      { label: 'Quick Start', href: '/getting-started/quick-start/' },
      { label: 'API Reference', href: '/api-reference/' },
    ],
  },
  {
    title: 'Guides',
    links: [
      { label: 'Backends', href: '/backends/overview/' },
      { label: 'Tools & Permissions', href: '/tools/tools-and-permissions/' },
      { label: 'Testing', href: '/testing/testing/' },
    ],
  },
  {
    title: 'Links',
    links: [
      { label: 'GitHub', href: 'https://github.com/witqq/agent-sdk' },
      { label: 'npm', href: 'https://www.npmjs.com/package/@witqq/agent-sdk' },
      { label: 'Changelog', href: 'https://github.com/witqq/agent-sdk/blob/master/CHANGELOG.md' },
    ],
  },
];
---

<footer class="footer">
  <div class="footer-grid">
    {columns.map((col) => (
      <div class="footer-col">
        <h4>{col.title}</h4>
        <ul>
          {col.links.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>
  <div class="footer-copy">
    © 2026 @witqq/agent-sdk. MIT License.
  </div>
  <div class="made-with-moira">
    <a href="https://moira-mcp.com" target="_blank" rel="noopener noreferrer">
      <span class="moira-icon">⚡</span>
      Made with <strong>Moira</strong>
    </a>
  </div>
</footer>
