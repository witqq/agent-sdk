    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.1",
    "@types/react-dom": "^19.2.3",
    "ai": "^6.0.73",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "jsdom": "^28.1.0",
    "react-dom": "^19.2.4",
    "testfold": "^0.2.1",
    "tsup": "^8.4.0",
