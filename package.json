{
  "name": "agent-sdk-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/sdk",
    "test": "npm run test -w packages/sdk",
    "test:e2e": "npm run test:e2e -w packages/sdk",
    "test:all": "npm run test:all -w packages/sdk",
    "typecheck": "npm run typecheck -w packages/sdk",
    "demo": "tsx scripts/demo.ts",
    "demo:start": "npm run start -w packages/demo",
    "demo:mock": "npm run start:mock -w packages/demo",
    "docs:api": "npm run docs:api -w packages/sdk",
    "docs:site": "cd packages/docs-site && npm run build",
    "docs:docker": "cd packages/docs-site && docker compose up -d --build",
    "docs:docker:stop": "cd packages/docs-site && docker compose down"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
